<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE struts-config PUBLIC
"-//Apache Software Foundation//DTD Struts Configuration 1.3//EN"
"http://jakarta.apache.org/struts/dtds/struts-config_1_3.dtd">

<struts-config>

<form-beans>

<form-bean
name="loginbean"
type="com.myapp.struts.loginbean"/>

</form-beans>

<global-forwards>

<forward
name="success"
path="/success.jsp"/>

<forward
name="failure"
path="/failure.jsp"/>

</global-forwards>

<action-mappings>

<action
name="loginbean"
path="/loginform"
scope="request"
type="com.myapp.struts.loginform"
validate="false">

<forward
name="success"
path="/success.jsp"/>

<forward
name="failure"
path="/failure.jsp"/>

</action>

</action-mappings>

</struts-config>
